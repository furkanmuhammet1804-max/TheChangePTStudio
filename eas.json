{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "production": {
      "autoIncrement": true
    },
    "customer-apk": {
      "android": {
        "buildType": "apk"
      }
    },
    "admin": {
      "extends": "production",
      "env": {
        "APP_VARIANT": "admin"
      }
    },
    "admin-apk": {
      "env": {
        "APP_VARIANT": "admin"
      },
      "android": {
        "buildType": "apk"
      }
    }
  }
}
